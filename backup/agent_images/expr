#!/bin/bash
# 에이전트 표정/말풍선 설정 헬퍼
# Usage: expr <agent> <expression> [speech]
#   expr klukai proud "전부 처리했어."
#   expr klukai normal          ← 표정만 변경, 말풍선 제거

AGENT="$1"
EXPRESSION="$2"
SPEECH="${3:-}"

echo -n "$EXPRESSION" > ~/."${AGENT}_expression"

if [ -n "$SPEECH" ]; then
    echo -n "$SPEECH" > ~/."${AGENT}_speech"
else
    echo -n "" > ~/."${AGENT}_speech"
fi
